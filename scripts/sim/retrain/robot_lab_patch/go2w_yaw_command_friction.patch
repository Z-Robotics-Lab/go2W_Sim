+        # ==== YAW ROUND (CEO B-plan, 2026-07-12): deployment wheel-friction domain =========
+        # Root cause #2 for the zero-yaw symptom (wz=1.4 -> 0.48 deg/s, in-place-yaw ~2%):
+        # deployment binds the 4 fixed-axis wheels to a HIGH-traction material
+        # (warehouse_nav.py:193-451  mu_s=1.8 / mu_d=1.6, friction_combine_mode="max",
+        # office marble). A 4-wheel skid-steer body can ONLY spin in place by SCRUBBING the
+        # wheels laterally against the ground — that costs traction the trained policy never
+        # had. Training ground is static=1.0/dynamic=1.0 combine="multiply"
+        # (velocity_env_cfg.py:53-58) and the robot-material randomization is capped at
+        # static<=1.0 / dynamic<=0.8 (velocity_env_cfg.py:267-268). With combine="multiply"
+        # the effective wheel-ground friction TOPS OUT at ~1.0 and averages far below the
+        # deployment 1.6-1.8 -> the scrub regime required for in-place yaw is OUT of training.
+        # FIX: center the robot-material friction randomization on the deployment values and
+        # switch the terrain combine mode to "max" so the effective friction MATCHES the
+        # office marble the policy is deployed on. Random domain (not a single point) keeps
+        # the policy robust to floor variation; the deployment 1.8/1.6 sits INSIDE it.
+        # Deployment-consistency RED LINE untouched: actuator gains, decimation, obs57/act16
+        # unchanged -> new ckpt stays isomorphic to the go2w_policy.py shim.
+        self.events.randomize_rigid_body_material.params["static_friction_range"] = (1.4, 2.0)
+        self.events.randomize_rigid_body_material.params["dynamic_friction_range"] = (1.2, 1.8)
+        # combine="max" so effective mu = max(robot_mat, ground_mat) tracks the high wheel
+        # value (mirrors warehouse_nav.py:451 friction_combine_mode="max"), instead of the
+        # parent "multiply" which suppresses it below either operand.
+        self.scene.terrain.physics_material.friction_combine_mode = "max"
